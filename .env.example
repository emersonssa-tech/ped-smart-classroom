APP_NAME=PED Smart Classroom
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# NuvemPed client
NUVEMPED_BASE_URL=http://localhost:8001
NUVEMPED_API_KEY=
NUVEMPED_TIMEOUT=3.0
NUVEMPED_RETRIES=1

# Cache offline-first
NUVEMPED_CACHE_PATH=.cache/nuvemped.json
NUVEMPED_CACHE_TTL=3600
NUVEMPED_CURRENT_CLASS_TTL=60

# Vision / Webcam
# Ligue com true quando tiver webcam conectada. Em dev sem câmera, deixe false.
CAMERA_ENABLED=false
CAMERA_INDEX=0
CAMERA_FRAME_WIDTH=320
CAMERA_MIN_FACE_SIZE=60
CAMERA_DETECTION_INTERVAL=0.5
CAMERA_DETECTION_COOLDOWN=10.0

# ===========================================================
# Cloud / piloto
# ===========================================================

# LLM (opcional). Se não setar, cai em regras.
# VOICE_AI_API_KEY=sk-ant-...
# VOICE_AI_PROVIDER=anthropic
# VOICE_AI_MODEL=claude-3-5-haiku-latest
# VOICE_AI_MODE=auto

# Auth opcional — se setada, exige header X-API-Key.
# API_KEY=troque-em-producao-string-longa-aleatoria

# CORS — em produção restrinja ao domínio do frontend.
# CORS_ORIGINS=*

# Persistência: aponte pra volume montado quando em cloud.
# ANALYTICS_SQLITE_PATH=/data/analytics/events.db
# TELEMETRY_VOICE_PATH=/data/telemetry/voice.jsonl
# MEMORY_PATH=/data/memory/memory_store.json
